# Anthropic — required for PDF parsing, AI fill, and practice sentence generation
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — optional; app falls back to browser SpeechSynthesis when not set
# Pick a voice that supports Mandarin from https://elevenlabs.io/voice-library
# "Lily" (pFZP5JQG7iQjIQuC4Bku) works well for Mandarin
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
