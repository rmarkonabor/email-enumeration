# --- Required ---
# Set this to a long random string. Send it as the X-API-Key header on requests.
# Generate one with: openssl rand -hex 32
API_KEY=change-me-to-a-long-random-string

# --- SMTP identity ---
# The address presented in MAIL FROM. Use a real address on a domain you own;
# many mail servers reject obviously-fake senders.
SENDER_EMAIL=verify@yourdomain.com

# The hostname presented in EHLO. Should be a real FQDN that resolves and
# ideally has a matching PTR (reverse DNS) record. Improves acceptance rates.
HELO_HOSTNAME=verifier.yourdomain.com

# --- CORS ---
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# --- Behavior ---
SMTP_TIMEOUT=10
PACING_SECONDS=0.3
LOG_LEVEL=INFO

# --- Multi-region ---
# Label for this server. Jobs are tagged with this region so workers on other
# servers don't pick them up when sharing a database.
# Examples: us | eu | sea | au
SERVER_REGION=us

# Comma-separated region=url pairs for admin server health fan-out.
# The primary server fetches /admin/server from each listed URL and aggregates.
# Include all servers (the primary will skip its own region automatically).
# MONITORED_SERVERS=us=https://verify1.mailcheckhq.com,eu=https://eu.verify.mailcheckhq.com

# --- Storage ---
DB_PATH=./data/cache.db
CATCH_ALL_TTL_SECONDS=2592000   # 30 days
VERIFIED_TTL_SECONDS=1209600    # 14 days
